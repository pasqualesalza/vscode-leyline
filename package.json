{
  "name": "leyline",
  "displayName": "Leyline",
  "description": "Lightweight inline code completion using configurable AI endpoints",
  "version": "0.1.0",
  "publisher": "pasqualesalza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pasqualesalza/vscode-leyline"
  },
  "homepage": "https://github.com/pasqualesalza/vscode-leyline#readme",
  "bugs": {
    "url": "https://github.com/pasqualesalza/vscode-leyline/issues"
  },
  "keywords": [
    "inline completion",
    "code completion",
    "AI",
    "copilot alternative",
    "ghost text",
    "azure openai",
    "openai"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Programming Languages",
    "Machine Learning"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false,
      "description": "Requires network access to AI endpoints."
    },
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Endpoint and deployment settings are ignored in untrusted workspaces to prevent API key exfiltration.",
      "restrictedConfigurations": [
        "leyline.endpoint",
        "leyline.deployment",
        "leyline.apiVersion",
        "leyline.model",
        "leyline.provider"
      ]
    }
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "leyline.setApiKey",
        "title": "Leyline: Set API Key"
      },
      {
        "command": "leyline.toggle",
        "title": "Leyline: Toggle Inline Completion"
      },
      {
        "command": "leyline.selectProvider",
        "title": "Leyline: Select Provider"
      }
    ],
    "configuration": {
      "title": "Leyline",
      "properties": {
        "leyline.provider": {
          "type": "string",
          "enum": [
            "azure-openai",
            "openai"
          ],
          "default": "azure-openai",
          "scope": "machine-overridable",
          "description": "Completion provider to use"
        },
        "leyline.endpoint": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "API endpoint URL (e.g., https://my-resource.openai.azure.com)"
        },
        "leyline.deployment": {
          "type": "string",
          "default": "gpt-5.1-codex-mini",
          "scope": "machine-overridable",
          "description": "Azure OpenAI deployment name"
        },
        "leyline.apiVersion": {
          "type": "string",
          "default": "2024-06-01",
          "scope": "machine-overridable",
          "description": "Azure OpenAI API version"
        },
        "leyline.model": {
          "type": "string",
          "default": "gpt-4o",
          "scope": "machine-overridable",
          "description": "Model name (for OpenAI provider)"
        },
        "leyline.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completion"
        },
        "leyline.maxTokens": {
          "type": "number",
          "default": 256,
          "minimum": 1,
          "maximum": 4096,
          "description": "Maximum tokens in completion response"
        },
        "leyline.temperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature (0 = deterministic)"
        },
        "leyline.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 5000,
          "description": "Debounce delay in milliseconds before sending a request"
        },
        "leyline.prefixLines": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "description": "Number of lines before the cursor to include as context"
        },
        "leyline.suffixLines": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 500,
          "description": "Number of lines after the cursor to include as context"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "vscode:prepublish": "tsc --noEmit && node esbuild.js --production",
    "package": "bunx @vscode/vsce package --no-dependencies",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3",
    "esbuild": "^0.27.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
